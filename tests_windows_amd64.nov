    if (str_equals(got, expected)) { test_pass(name); return 0; }
    test_fail(name, "got '" + got + "', expected '" + expected + "'");
    return 1;
}

fn assert_true(name: str, val: bool) -> i32 {
    if (val) { test_pass(name); return 0; }
    test_fail(name, "expected true");
    return 1;
}

fn assert_gt_i32(name: str, val: i32, threshold: i32) -> i32 {
    if (val > threshold) { test_pass(name); return 0; }
    test_fail(name, "expected > " + i32_to_str(threshold));
    return 1;
}

fn assert_gt_i64(name: str, val: i64, threshold: i64) -> i32 {
